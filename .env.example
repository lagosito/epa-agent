# =============================================================================
# ePA Agent — Environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (EU Frankfurt region MANDATORY for health data)
# Region must be eu-central-1 (Frankfurt) — verify in project settings.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Anthropic Claude API
# IMPORTANT: Request Zero Data Retention (ZDR) addendum for health data.
# Without ZDR, prompts are retained 30 days. With ZDR, 0 days.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PARSER=claude-opus-4-7
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
# Set to 'true' once ZDR contract is signed
ANTHROPIC_ZDR_ENABLED=false

# -----------------------------------------------------------------------------
# Azure Document Intelligence (Tier 2 OCR for tabular Laborwerte)
# Region must be EU (West Europe / Germany West Central)
# -----------------------------------------------------------------------------
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://xxx.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=

# -----------------------------------------------------------------------------
# Stripe (billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_YEARLY=price_

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ePA Agent
NODE_ENV=development

# -----------------------------------------------------------------------------
# Cron secret (for Vercel Cron / Supabase Edge Functions to invoke /api/cron/*)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Email (transactional — for magic links, deletion confirmations)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@epa-agent.de
EMAIL_REPLY_TO=support@epa-agent.de

# -----------------------------------------------------------------------------
# DSGVO / Compliance
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DPO_NAME=
NEXT_PUBLIC_DPO_EMAIL=datenschutz@epa-agent.de
NEXT_PUBLIC_COMPANY_NAME=Make Happen GmbH
NEXT_PUBLIC_COMPANY_ADDRESS=Schulweg 22, 20259 Hamburg
NEXT_PUBLIC_COMPANY_HRB=HRB 136558 Amtsgericht Hamburg
